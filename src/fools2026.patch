+void zInitPasswordData(void) {
+    zPasswordData[0] = 0xf4;
+    zPasswordData[1] = 0xca;
+    zPasswordData[2] = 0xbe;
+    zPasswordData[3] = 0x81;
+    zPasswordData[4] = 0x50;
+}
+
+void zFeedPasswordData(u8 push) {
+    // rotate
+    vs32 i,j;
+    i=4; j=4;
+    for (;;) {
+        zPasswordData[i] ^= zPasswordData[j];
+        j--;
+        zPasswordData[i] ^= zPasswordData[j];
+        i--;
+        if (i == 0) break;
+    }
+    // xor with previous
+    zPasswordData[i] ^= zPasswordData[j];
+    zPasswordData[i] ^= push;
+    zPasswordData[i] ^= zPasswordData[1];
+}
+
+u8 zUnfeedPasswordData(void) {
+    // xor with previous
+    u8 result = zPasswordData[0] ^ zPasswordData[1];
+    // rotate
+    vs32 i,j;
+    i=0; j=0;
+    for (;;) {
+        zPasswordData[i] ^= zPasswordData[j];
+        j++;
+        zPasswordData[i] ^= zPasswordData[j];
+        i++;
+        if (j == 4) break;
+    }
+    return result;
+}
+
+void zPasswordFinalUpdate(void) {
+    *zPasswordFinalPass = zPersonalizedData->passwordSbox[zPasswordData[0]];
+    *zPasswordFinalPass ^= zPasswordData[1] ^ zPasswordData[2] ^ zPasswordData[3];
+    *zPasswordFinalPass = zPersonalizedData->passwordSbox[*zPasswordFinalPass];
+    zFeedPasswordData(*zPasswordFinalPass);
+}
