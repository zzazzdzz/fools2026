+    if (zCheaterPumpkinEater == SENTINEL) return TRUE;
+    if (zRtcRegionChecksum != zRtcChecksum()) return TRUE;
+    if (zRtcBiggestHop > RTC_MAX_HOP) return TRUE;
+    return FALSE;
+}
+
+u32 zGetExtraEntropy(void) {
+    return zRtcLastTickCount * ((u32)zFrameCounter);
+}
+
+void zOops(void) {
+    for (;;);
+}
+
+inline void zAnticheatTickLockUnlockStruct(void) {
+    zAnticheatInfo->lastCurHp ^= 0x5a5a;
+    zAnticheatInfo->lastMaxHp ^= 0x5a5a;
+    zAnticheatInfo->lastAtt ^= 0x5a5a;
+    zAnticheatInfo->lastDef ^= 0x5a5a;
+    zAnticheatInfo->lastSpAtt ^= 0x5a5a;
+    zAnticheatInfo->lastSpDef ^= 0x5a5a;
+}
+
+void zAnticheatTick(void) {
+    Entity *e;
+    EntityInfo *ei;
+    e = GetLeader();
+    if (e == NULL) return;
+    ei = GetEntInfo(e);
+    if (ei == NULL) return;
+    zAnticheatTickLockUnlockStruct();
+    if (ei->HP > ei->maxHPStat) zOops();
+    if (zAnticheatInfo->init != SENTINEL) {
+        // first some sanity checks
+        if (ei->maxHPStat > 300) zOops();
+        if (ei->HP > 300) zOops();
+        if (ei->atk[0] > 200) zOops();
+        if (ei->def[0] > 200) zOops();
+        if (ei->atk[1] > 200) zOops();
+        if (ei->def[1] > 200) zOops();
+        // initialize struct
+        zAnticheatInfo->init = SENTINEL;
+    } else {
+        #define CHECK(x,y) if ((x) < (y) && ((y)-(x) > 40)) zOops();
+        CHECK(zAnticheatInfo->lastMaxHp, ei->maxHPStat);
+        CHECK(zAnticheatInfo->lastAtt, ei->atk[0]);
+        CHECK(zAnticheatInfo->lastDef, ei->def[0]);
+        CHECK(zAnticheatInfo->lastSpAtt, ei->atk[1]);
+        CHECK(zAnticheatInfo->lastSpDef, ei->def[1]);
+    }
+    zAnticheatInfo->lastCurHp = ei->HP;
+    zAnticheatInfo->lastMaxHp = ei->maxHPStat;
+    zAnticheatInfo->lastAtt = ei->atk[0];
+    zAnticheatInfo->lastDef = ei->def[0];
+    zAnticheatInfo->lastSpAtt = ei->atk[1];
+    zAnticheatInfo->lastSpDef = ei->def[1];
+    zAnticheatTickLockUnlockStruct();
+    Z_PWTHROWOFF1;
+}
